# Supabase — https://supabase.com/dashboard/project/_/settings/api
# Для деплоя (Amvera/Docker) используйте NUXT_* — они подхватываются в runtime без пересборки.
NUXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NUXT_PUBLIC_SUPABASE_KEY=your-anon-key
NUXT_SUPABASE_SERVICE_KEY=your-service-role-key

# Локально также работают legacy-имена:
# SUPABASE_URL=...
# SUPABASE_ANON_KEY=...
# SUPABASE_SERVICE_ROLE_KEY=...

# SDESK — исходящие вызовы (Finance → SDESK)
# SDESK_TOKEN=...
# SDESK_CREATE_APPEAL_URL=...

# SDESK — входящие вызовы (SDESK → Finance), см. docs/sdesk-inbound-api.md
SDESK_INBOUND_TOKEN=your-inbound-integration-token
